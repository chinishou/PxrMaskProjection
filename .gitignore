*.dll
*.so
*.dylib
*.obj
*.o
*.exp
*.lib
*.a
*.pdb
*.ilk

# Editor / IDE
.vs/
.vscode/
*.swp
*.swo
.idea/
*.user

# OS
.DS_Store
Thumbs.db

# Claude Code local state
.claude/
